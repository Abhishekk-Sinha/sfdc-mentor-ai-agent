# Backend environment example for local/Render deployment
# Never commit real API keys, Gmail passwords, or app passwords.

APP_ENV=production
FRONTEND_URL=https://abhishekk-sinha.github.io/sfdc-mentor-ai-agent
BACKEND_URL=https://sfdc-mentor-backend.onrender.com
CORS_ORIGINS=https://abhishekk-sinha.github.io,http://localhost:5173,http://127.0.0.1:5173

# App security
APP_SECRET=change-this-to-a-long-random-secret
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
OTP_TTL_SECONDS=600

# Local database
DATABASE_URL=sqlite:///mentor_storage.sqlite3

# Primary email provider: Resend
# Add the real API key only in Render Environment Variables.
RESEND_API_KEY=your_resend_api_key_here
MAIL_FROM=onboarding@resend.dev

# Fallback email provider: Gmail SMTP
# Use a Gmail App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_character_gmail_app_password_without_spaces

# Local AI. Free if Ollama is installed on your PC.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=240

# Optional cloud/API keys
OPENAI_API_KEY=
SERPAPI_API_KEY=
TAVILY_API_KEY=
RAPIDAPI_KEY=

# Local upload folder
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20
