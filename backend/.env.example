# FREE-ONLY BACKEND CONFIG
# Copy this file to backend/.env if you want environment variables.
# Do not add paid API keys. This app will run with SQLite + local Ollama + fallback links.

APP_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://127.0.0.1:8000

# Local database. Free.
DATABASE_URL=sqlite:///mentor_storage.sqlite3

# Local app secret. Change this text locally. Free.
SECRET_KEY=change-this-free-local-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local AI. Free if Ollama is installed on your PC.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Paid/cloud keys intentionally disabled for free version.
OPENAI_API_KEY=
SERPAPI_API_KEY=
TAVILY_API_KEY=
RAPIDAPI_KEY=

# Local upload folder. Free.
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20
